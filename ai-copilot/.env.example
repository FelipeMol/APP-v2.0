# Configurações da IA Copilot
# Copie este arquivo para .env e preencha os valores

# ── LLM ─────────────────────────────────────────────────────────
# Escolha o provedor: openai | anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternativa)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Supabase (MCP de banco) ──────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Ou conexão direta ao Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ─────────────────────────────────────────────────────────
# Segredo JWT (mesmo usado pelo backend principal)
JWT_SECRET=seu_jwt_secret_aqui

# ── Servidor ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,https://seu-dominio.com.br
